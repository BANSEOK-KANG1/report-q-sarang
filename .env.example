# NCBI E-utilities (free key increases rate limit to 10 req/s)
# https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# OpenAlex polite pool (use a real email)
OPENALEX_EMAIL=you@example.com

# Notion integration
# https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_DB_ID=
NOTION_PARENT_PAGE_ID=

# Obsidian vault path (absolute). Default: ./vault inside this repo
OBSIDIAN_VAULT_PATH=

# WordPress — measuremkt.com hub (q-sarang = Vercel, not WP)
# Setup: docs/WORDPRESS_SETUP.md
WP_BASE_URL=https://measuremkt.com
WP_TARGET=parent
WP_USERNAME=
WP_APP_PASSWORD=
